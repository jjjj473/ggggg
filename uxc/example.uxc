component HelloWorld
view:
  div id=main:
    h1: Hello UXC
    input :model=name persist=userName
    button onclick.prevent=sayHello :class=btnClass: Greet
    ul:
      li each=items: Item
logic:
  var name = ''
  var btnClass = 'primary'
  var items = ['A','B','C']
  function sayHello() {
    alert('Hello ' + name);
  }
